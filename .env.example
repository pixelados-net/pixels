# Pixels environment name.
# Default: development
PIXELS_ENV=development

# Host used by the protocol listener.
# Default: 127.0.0.1
PIXELS_HOST=127.0.0.1

# Port used by the protocol listener.
# Default: 3000
PIXELS_PORT=3000

# Access key required by private HTTP endpoints.
# Header: X-API-Key
# Default: pixels-dev-key
PIXELS_ACCESS_KEY=pixels-dev-key

# Zap log level.
# Allowed values: debug, info, warn, error, dpanic, panic, fatal
# Default: info
LOG_LEVEL=info

# Zap log encoder.
# Allowed values: console, json
# Default: console
LOG_FORMAT=console

# Emit inline TOON logs for agent-friendly protocol tracing.
# Removes timestamps/callers and normalizes packet fields before TOON encoding.
# Default: false
TOON_CONSOLE=false

# Redis address used by reusable storage components.
# Default: 127.0.0.1:6379
REDIS_ADDRESS=127.0.0.1:6379

# Redis username.
# Default: empty
REDIS_USERNAME=

# Redis password.
# Default: empty
REDIS_PASSWORD=

# Redis database number.
# Default: 0
REDIS_DATABASE=0

# PostgreSQL host.
# Default: localhost
PIXELS_POSTGRES_HOST=localhost

# PostgreSQL port.
# Default: 5432
PIXELS_POSTGRES_PORT=5432

# PostgreSQL database name.
# Default: pixels
PIXELS_POSTGRES_DATABASE=pixels

# PostgreSQL user.
# Default: pixels
PIXELS_POSTGRES_USER=pixels

# PostgreSQL password for development.
# Default: pixels
PIXELS_POSTGRES_PASSWORD=pixels

# PostgreSQL SSL mode.
# Default: disable
PIXELS_POSTGRES_SSL_MODE=disable

# Maximum PostgreSQL pool connections.
# Default: 10
PIXELS_POSTGRES_MAX_CONNS=10

# Minimum PostgreSQL pool connections.
# Default: 1
PIXELS_POSTGRES_MIN_CONNS=1

# PostgreSQL connection timeout.
# Default: 5s
PIXELS_POSTGRES_CONNECT_TIMEOUT=5s

# PostgreSQL statement timeout.
# Default: 5s
PIXELS_POSTGRES_STATEMENT_TIMEOUT=5s

# PostgreSQL health check timeout.
# Default: 2s
PIXELS_POSTGRES_HEALTH_TIMEOUT=2s

# Default SSO ticket lifetime.
# Default: 5m
SSO_DEFAULT_TTL=5m

# HMAC key used to derive Redis storage keys for SSO tickets.
# Default: pixels-development-sso-key-change-me
SSO_KEY=pixels-development-sso-key-change-me

# Redis key prefix for SSO tickets.
# Default: pixels:sso
SSO_PREFIX=pixels:sso

# Maximum queued outbound WebSocket packets per connection.
# Default: 256
PIXELS_WS_QUEUE_SIZE=256

# Maximum duration for one WebSocket write.
# Default: 5s
PIXELS_WS_WRITE_TIMEOUT=5s

# Maximum duration for one WebSocket read.
# Default: 75s
PIXELS_WS_READ_TIMEOUT=75s

# Interval between server heartbeat pings.
# Default: 30s
PIXELS_WS_PING_INTERVAL=30s

# Maximum duration without a client pong before disconnecting.
# Default: 60s
PIXELS_WS_PONG_TIMEOUT=60s

# Maximum graceful close flushing duration.
# Default: 2s
PIXELS_WS_CLOSE_GRACE=2s
