# Pixels environment name.
# Default: development
PIXELS_ENV=development

# Host used by the protocol listener.
# Default: 127.0.0.1
PIXELS_HOST=127.0.0.1

# Port used by the protocol listener.
# Default: 3000
PIXELS_PORT=3000

# Access key required by private HTTP endpoints.
# Header: X-API-Key
# Use a long random value and share it only with trusted HTTP clients.
# Default: pixels-development-access-key-change-me
PIXELS_ACCESS_KEY=pixels-development-access-key-change-me

# Inbound inactivity required before a room avatar is projected as AFK.
# Default: 5m
PIXELS_ROOM_IDLE_TIMEOUT=5m

# Cadence of the single process-wide room AFK reconciliation loop.
# Default: 1s
PIXELS_ROOM_IDLE_SWEEP_INTERVAL=1s

# Brief pause between cancelling one avatar action and starting another.
# Default: 100ms
PIXELS_ROOM_ACTION_TRANSITION_DELAY=100ms

# Zap log level.
# Allowed values: debug, info, warn, error, dpanic, panic, fatal
# Default: info
LOG_LEVEL=info

# Zap log encoder.
# Allowed values: console, json
# Default: console
LOG_FORMAT=console

# Emit inline TOON logs for agent-friendly protocol tracing.
# Removes timestamps/callers and normalizes packet fields before TOON encoding.
# Default: false
TOON_CONSOLE=false

# JSON translation catalog path.
# Default: i18n/translations.json
PIXELS_I18N_PATH=i18n/translations.json

# Default locale used when no player locale is available.
# Default: es
PIXELS_I18N_DEFAULT_LOCALE=es

# Fallback locale used when a key is missing in the default locale.
# Default: en
PIXELS_I18N_FALLBACK_LOCALE=en

# Missing translation behavior.
# Allowed values: key, empty
# Default: key
PIXELS_I18N_MISSING_MODE=key

# Comma-separated Nitro currency definitions in type:localization-key form.
# Keys resolve through currency.name.<key> in the i18n catalog.
# Default: -1:credits,0:duckets,5:diamonds
PIXELS_CURRENCY_TYPES=-1:credits,0:duckets,5:diamonds

# Comma-separated currency types that write an audit ledger entry.
# Types not listed still update their balances without ledger history.
# Default: -1 (credits only)
PIXELS_CURRENCY_LEDGER_TYPES=-1

# Directory containing plugins/<name>/*.so. Missing directories are allowed.
# Default: plugins
PIXELS_PLUGIN_DIRECTORY=plugins

# Maximum duration of one plugin interceptor, listener, or command callback.
# Default: 2s
PIXELS_PLUGIN_CALLBACK_TIMEOUT=2s

# Prefix that turns room chat into a plugin command instead of visible speech.
# Default: :
PIXELS_COMMAND_PREFIX=:

# Redis address used by reusable storage components.
# Default: 127.0.0.1:6379
REDIS_ADDRESS=127.0.0.1:6379

# Redis username.
# Default: empty
REDIS_USERNAME=

# Redis password.
# Default: empty
REDIS_PASSWORD=

# Redis database number.
# Default: 0
REDIS_DATABASE=0

# Maximum time a doorbell request waits for approval.
# Default: 5m
PIXELS_ROOM_ENTRY_HANGOUT_TIMEOUT=5m

# Failed room password attempts allowed before lockout.
# Default: 5
PIXELS_ROOM_ENTRY_MAX_PASSWORD_ATTEMPTS=5

# Window in which failed room password attempts accumulate.
# Default: 5m
PIXELS_ROOM_ENTRY_ATTEMPT_WINDOW=5m

# Duration of a room password lockout, in seconds.
# The user-facing alert converts this value to seconds, minutes, hours, or days.
# Default: 600
PIXELS_ROOM_ENTRY_LOCKOUT_SECONDS=600

# Bcrypt cost used when room passwords are hashed.
# Default: 10
PIXELS_ROOM_ENTRY_PASSWORD_COST=10

# Lifetime of a one-time admin room entry bypass.
# Default: 10s
PIXELS_ROOM_ENTRY_TRUSTED_TTL=10s

# Minimum room mute duration accepted by the moderation service, in minutes.
PIXELS_ROOM_MODERATION_MIN_MUTE_MINUTES=1

# Maximum room mute duration accepted by the moderation service, in minutes.
PIXELS_ROOM_MODERATION_MAX_MUTE_MINUTES=1440

# Maximum Unicode runes accepted in a normal chat message.
# Default: 256
PIXELS_CHAT_MAX_MESSAGE_RUNES=256

# Loose room flood budget and expiration window.
# Default: 100 messages per 1s
PIXELS_CHAT_FLOOD_TIER0_MAX_MESSAGES=100
PIXELS_CHAT_FLOOD_TIER0_WINDOW=1s

# Normal room flood budget and expiration window.
# Default: 10 messages per 5s
PIXELS_CHAT_FLOOD_TIER1_MAX_MESSAGES=10
PIXELS_CHAT_FLOOD_TIER1_WINDOW=5s

# Strict room flood budget and expiration window.
# Default: 6 messages per 5s
PIXELS_CHAT_FLOOD_TIER2_MAX_MESSAGES=6
PIXELS_CHAT_FLOOD_TIER2_WINDOW=5s

# Persist private whispers in moderation history.
# Default: false
PIXELS_CHAT_LOG_WHISPERS=false

# Daily chat history partitions retained before DROP TABLE.
# Default: 14
PIXELS_CHAT_LOG_RETENTION_DAYS=14

# Maximum delay and row count for one asynchronous history COPY batch.
# Defaults: 2s and 200
PIXELS_CHAT_LOG_FLUSH_INTERVAL=2s
PIXELS_CHAT_LOG_FLUSH_BATCH_SIZE=200

# Non-blocking chat history queue capacity.
# Default: 4096
PIXELS_CHAT_LOG_QUEUE_SIZE=4096

# PostgreSQL host.
# Default: localhost
PIXELS_POSTGRES_HOST=localhost

# PostgreSQL port.
# Default: 5432
PIXELS_POSTGRES_PORT=5432

# PostgreSQL database name.
# Default: pixels
PIXELS_POSTGRES_DATABASE=pixels

# PostgreSQL user.
# Default: pixels
PIXELS_POSTGRES_USER=pixels

# PostgreSQL password for development.
# Default: pixels
PIXELS_POSTGRES_PASSWORD=pixels

# PostgreSQL SSL mode.
# Default: disable
PIXELS_POSTGRES_SSL_MODE=disable

# Maximum PostgreSQL pool connections.
# Default: 10
PIXELS_POSTGRES_MAX_CONNS=10

# Minimum PostgreSQL pool connections.
# Default: 1
PIXELS_POSTGRES_MIN_CONNS=1

# PostgreSQL connection timeout.
# Default: 5s
PIXELS_POSTGRES_CONNECT_TIMEOUT=5s

# PostgreSQL statement timeout.
# Default: 5s
PIXELS_POSTGRES_STATEMENT_TIMEOUT=5s

# PostgreSQL health check timeout.
# Default: 2s
PIXELS_POSTGRES_HEALTH_TIMEOUT=2s

# Default SSO ticket lifetime.
# Default: 5m
SSO_DEFAULT_TTL=5m

# HMAC key used to derive Redis storage keys for SSO tickets.
# Default: pixels-development-sso-key-change-me
SSO_KEY=pixels-development-sso-key-change-me

# Redis key prefix for SSO tickets.
# Default: pixels:sso
SSO_PREFIX=pixels:sso

# Maximum queued outbound WebSocket packets per connection.
# Default: 256
PIXELS_WS_QUEUE_SIZE=256

# Maximum duration for one WebSocket write.
# Default: 5s
PIXELS_WS_WRITE_TIMEOUT=5s

# Maximum duration for one WebSocket read.
# Default: 75s
PIXELS_WS_READ_TIMEOUT=75s

# Interval between server heartbeat pings.
# Default: 30s
PIXELS_WS_PING_INTERVAL=30s

# Maximum duration without a client pong before disconnecting.
# Default: 60s
PIXELS_WS_PONG_TIMEOUT=60s

# Maximum graceful close flushing duration.
# Default: 2s
PIXELS_WS_CLOSE_GRACE=2s

# Reject custom room floor plans that contain no usable tile.
# Default: true
PIXELS_ROOM_FLOORPLAN_REJECT_ZERO_HEIGHT=true

# Minimum delay between successful floor plan saves by one player.
# Default: 3s
PIXELS_ROOM_FLOORPLAN_SAVE_COOLDOWN=3s

# Allow paired furniture teleports to bypass locked destination room modes. Room bans always apply.
# Default: false
PIXELS_FURNITURE_TELEPORT_BYPASS_LOCKED=false
# Normal messenger friend-list capacity.
# Default: 200
PIXELS_MESSENGER_MAX_FRIENDS=200

# Active HC messenger friend-list capacity.
# Default: 500
PIXELS_MESSENGER_MAX_FRIENDS_CLUB=500

# Maximum players returned by a username-prefix search.
# Default: 50
PIXELS_MESSENGER_SEARCH_MAX_RESULTS=50

# Shared Redis lifetime for username-prefix search results.
# Default: 30s
PIXELS_MESSENGER_SEARCH_CACHE_TTL=30s

# Shared Redis lifetime for durable friend-card details; live presence is overlaid per request.
# Default: 30s
PIXELS_MESSENGER_FRIEND_CACHE_TTL=30s

# Minimum interval between messenger searches by one player.
# Default: 3s
PIXELS_MESSENGER_SEARCH_THROTTLE=3s

# Minimum interval between private messages by one sender.
# Default: 750ms
PIXELS_MESSENGER_CHAT_THROTTLE=750ms

# Apply the global hotel word filter to private messages.
# Default: false
PIXELS_MESSENGER_CHAT_FILTER_ENABLED=false

# Persist accepted private messages for moderation review.
# Default: false
PIXELS_MESSENGER_CHAT_LOG_ENABLED=false

# Interval between subscription entitlement and payday scheduler passes.
# Default: 1m
PIXELS_SUBSCRIPTION_TICK_INTERVAL=1m

# Duration of one HC payday accounting cycle.
# Default: 744h (31 days)
PIXELS_SUBSCRIPTION_PAYDAY_INTERVAL=744h

# Fraction of eligible catalog credit spending returned at payday.
# Default: 0.10
PIXELS_SUBSCRIPTION_KICKBACK_PERCENTAGE=0.10

# Currency type receiving HC payday rewards; -1 identifies credits.
# Default: -1
PIXELS_SUBSCRIPTION_PAYDAY_CURRENCY_TYPE=-1

# Currency balance tracked by the hotel-view Bonus Rare widget.
PIXELS_SUBSCRIPTION_BONUSRARE_CURRENCY_TYPE=5

# Balance required to fill the Bonus Rare progress bar.
PIXELS_SUBSCRIPTION_BONUSRARE_THRESHOLD=120

# Furniture definition shown by Bonus Rare; 0 keeps the widget neutral.
PIXELS_SUBSCRIPTION_BONUSRARE_PRODUCT_ID=0

# Time purchased by each Room Ad promotion.
PIXELS_ROOM_PROMOTION_DURATION=2h
PIXELS_ROOM_SPECTATOR_ENABLED=true
PIXELS_FIREWORK_DEFAULT_RECHARGE=5s
PIXELS_RENTABLE_DURATION=24h
PIXELS_RENTABLE_PRICE_CREDITS=10
PIXELS_RENTABLE_BUYOUT_CREDITS=50
PIXELS_MYSTERYBOX_WAIT=3s
PIXELS_MYSTERYBOX_PRIZE_DEFINITION_ID=1

# Builders Club aliases stay dormant until a server-side subscription policy
# grants a positive room furniture allowance.
PIXELS_BUILDERS_CLUB_FURNITURE_LIMIT=0

# Enable Nitro Marketplace operations.
PIXELS_MARKETPLACE_ENABLED=true
# Buyer commission percentage, rounded upward.
PIXELS_MARKETPLACE_COMMISSION_PERCENT=1
# Credits charged per fixed Marketplace token package.
PIXELS_MARKETPLACE_TOKEN_COST=1
# Tokens granted per package.
PIXELS_MARKETPLACE_TOKEN_PACKAGE_SIZE=5
# Promoted-listing cost projected to Nitro; promotion is currently disabled.
PIXELS_MARKETPLACE_ADVERTISEMENT_COST=0
# Inclusive seller-price limits.
PIXELS_MARKETPLACE_MIN_PRICE=1
PIXELS_MARKETPLACE_MAX_PRICE=1000000
# Open offer and historical display lifetimes.
PIXELS_MARKETPLACE_OFFER_DURATION=48h
PIXELS_MARKETPLACE_DISPLAY_DURATION=168h
# Shared search cache and expiry scheduler cadence.
PIXELS_MARKETPLACE_SEARCH_CACHE_TTL=30s
PIXELS_MARKETPLACE_EXPIRY_INTERVAL=1m

# Enable direct player trading.
PIXELS_TRADE_ENABLED=true
# Minimum interval between trade-start requests.
PIXELS_TRADE_START_THROTTLE=10s
# Maximum offered furniture per participant.
PIXELS_TRADE_MAX_ITEMS=12
# Persist completed trade audit records.
PIXELS_TRADE_AUDIT_ENABLED=true

# Enable call-for-help, moderator tools, guides, and guardian reviews.
# Default: true
PIXELS_MODERATION_ENABLED=true
# Reports accepted per player in one distributed throttle window.
# Defaults: 3 reports per 10m
PIXELS_MODERATION_REPORT_LIMIT=3
PIXELS_MODERATION_REPORT_WINDOW=10m
# Maximum chat-history rows frozen into a new moderation issue.
# Default: 50
PIXELS_MODERATION_CONTEXT_WINDOW=50
# Guardian reviewers and voting window for one peer review.
# Defaults: 3 reviewers and 1m
PIXELS_GUARDIAN_COUNT=3
PIXELS_GUARDIAN_VOTE_WINDOW=1m
# Ignored guardian offers before temporary exclusion and its duration.
# Defaults: 3 ignored offers and 30m
PIXELS_GUARDIAN_IGNORE_LIMIT=3
PIXELS_GUARDIAN_EXCLUSION=30m

# Maximum bots ordinary players may place in one room or keep in inventory.
PIXELS_BOT_MAX_PER_ROOM=25
PIXELS_BOT_MAX_INVENTORY=25
# Random-walk radius and enforcement policy.
PIXELS_BOT_WALK_RADIUS=5
PIXELS_BOT_LIMIT_WALK_RADIUS=true
# Bartender hearing and delivery reach distances in tiles.
PIXELS_BOT_BARTENDER_COMMAND_DISTANCE=6
PIXELS_BOT_BARTENDER_REACH_DISTANCE=3
# Semicolon-separated localized greetings selected when a bot is placed.
PIXELS_BOT_PLACEMENT_MESSAGES=bots.placement.hello;bots.placement.party;bots.placement.welcome
# Minimum cadence for deferred durable position updates.
PIXELS_BOT_POSITION_FLUSH_INTERVAL=5s
# Clone bots placed in room bundle templates when a complete room is purchased.
PIXELS_ROOM_BUNDLE_BOTS_ENABLED=true

# Enable the pet realm, catalog rewards, placement, and room behavior.
PIXELS_PET_ENABLED=true
# Ordinary room, per-owner room, and inventory pet limits.
PIXELS_PET_MAX_PER_ROOM=25
PIXELS_PET_MAX_PER_OWNER_ROOM=10
PIXELS_PET_MAX_INVENTORY=25
# Maximum records in one Nitro USER_PETS fragment.
PIXELS_PET_INVENTORY_FRAGMENT_SIZE=100
# Autonomous walk radius and bounded decision jitter on the shared room tick.
PIXELS_PET_WALK_RADIUS=5
PIXELS_PET_DECISION_MINIMUM=5s
PIXELS_PET_DECISION_MAXIMUM=15s
# Minimum interval between coalesced durable position writes.
PIXELS_PET_POSITION_FLUSH_INTERVAL=5s
# Absolute need materialization cadence and per-interval decay.
PIXELS_PET_STAT_DECAY_INTERVAL=30m
PIXELS_PET_ENERGY_DECAY=1
PIXELS_PET_HAPPINESS_DECAY=1
# Respect age, experience, global daily budget, and owner policy.
PIXELS_PET_RESPECT_MINIMUM_AGE=72h
PIXELS_PET_RESPECT_EXPERIENCE=10
PIXELS_PET_RESPECT_DAILY_LIMIT=3
PIXELS_PET_ALLOW_RESPECT_OWN=false
# Monsterplant seed furniture reward and absolute lifecycle durations.
PIXELS_PET_PLANT_REWARD_DEFINITION_ID=4582
PIXELS_PET_PLANT_COMPOST_DEFINITION_ID=4830
PIXELS_PET_PLANT_GROW_DURATION=168h
PIXELS_PET_PLANT_LIFE_DURATION=168h
# Package, breeding, minimum parent age, and unload deadlines.
PIXELS_PET_PACKAGE_TIMEOUT=2m
PIXELS_PET_BREEDING_TIMEOUT=2m
PIXELS_PET_BREEDING_MINIMUM_AGE=72h
PIXELS_PET_UNLOAD_FLUSH_TIMEOUT=3s

# Navigator search, favorites, visit telemetry, and saved-window bounds.
PIXELS_NAVIGATOR_SEARCH_LIMIT=50
PIXELS_NAVIGATOR_HISTORY_LIMIT=25
PIXELS_NAVIGATOR_FAVORITE_LIMIT=30
PIXELS_NAVIGATOR_HISTORY_QUEUE_SIZE=1024
PIXELS_NAVIGATOR_HISTORY_DEDUPE_WINDOW=30s
PIXELS_NAVIGATOR_PREFERENCE_FLUSH_INTERVAL=250ms
PIXELS_NAVIGATOR_PREFERENCE_PENDING_LIMIT=4096
PIXELS_NAVIGATOR_WINDOW_POSITION_LIMIT=32768
PIXELS_NAVIGATOR_WINDOW_MIN_WIDTH=320
PIXELS_NAVIGATOR_WINDOW_MAX_WIDTH=4096
PIXELS_NAVIGATOR_WINDOW_MIN_HEIGHT=240
PIXELS_NAVIGATOR_WINDOW_MAX_HEIGHT=2160

# User identity, public-profile, respect, and wardrobe policy.
PIXELS_PLAYER_USERNAME_MIN_LENGTH=3
PIXELS_PLAYER_USERNAME_MAX_LENGTH=15
PIXELS_PLAYER_USERNAME_ALLOWED_SYMBOLS=_-=!?@:,.'
PIXELS_PLAYER_USERNAME_RESERVATION_TTL=2m
PIXELS_PLAYER_USERNAME_RESERVED=admin,moderator,staff,system
PIXELS_PLAYER_MOTTO_MAX_RUNES=38
PIXELS_PLAYER_TAG_MAX_COUNT=5
PIXELS_PLAYER_TAG_MAX_RUNES=32
PIXELS_PLAYER_RESPECT_DAILY_LIMIT=3
PIXELS_PLAYER_PET_RESPECT_DAILY_LIMIT=3
PIXELS_PLAYER_RESPECT_THROTTLE=250ms
PIXELS_HOTEL_TIMEZONE=America/Bogota
PIXELS_PLAYER_WARDROBE_MIN_SLOT=1
PIXELS_PLAYER_WARDROBE_MAX_SLOT=10
PIXELS_PLAYER_SETTINGS_FLUSH_INTERVAL=250ms
PIXELS_PLAYER_SETTINGS_PENDING_LIMIT=4096
# Immutable avatar entitlement registry loaded at startup. Use the exact
# FigureData.json served to Nitro, or a compatible legacy figuredata.xml.
PIXELS_FIGURE_DATA_PATH=legacy/Comet-KeyServers-Edition/config/figuredata.xml

# Delay between a roller animation and furniture walk hooks.
PIXELS_ROLLER_HOOK_DELAY=400ms
# Maximum stationary avatars moved by each roller in one room cycle.
PIXELS_ROLLER_MAX_AVATARS=1
# Disable roller placement and equal-height chain restrictions.
PIXELS_ROLLER_NO_RULES=false

# Enable room WIRED configuration and execution.
PIXELS_WIRED_ENABLED=true
# Maximum selected furniture and delayed action pulses per WIRED node.
PIXELS_WIRED_MAX_SELECTION=20
PIXELS_WIRED_MAX_DELAY_PULSES=7200
# Per-trace safety budgets for derived events, stacks, effects, and call depth.
PIXELS_WIRED_MAX_EVENTS_PER_TRACE=128
PIXELS_WIRED_MAX_STACKS_PER_TRACE=64
PIXELS_WIRED_MAX_EFFECTS_PER_TRACE=128
PIXELS_WIRED_MAX_CALL_DEPTH=10
# Maximum outstanding delayed actions per active room.
PIXELS_WIRED_MAX_DELAYED_PER_ROOM=512
# Maximum durable rows projected by one WIRED highscore board.
PIXELS_WIRED_HIGHSCORE_TOP=50

# Social groups, membership, badge, forum, cache, and bounded bulk operations.
PIXELS_GROUP_CREATION_COST=10
PIXELS_GROUP_REQUIRE_CLUB=true
PIXELS_GROUP_OWNED_LIMIT=100
PIXELS_GROUP_MEMBERSHIP_LIMIT=100
PIXELS_GROUP_MEMBER_LIMIT=50000
PIXELS_GROUP_PENDING_LIMIT=100
PIXELS_GROUP_MEMBER_PAGE_SIZE=14
PIXELS_GROUP_MAX_SEARCH_LENGTH=64
PIXELS_GROUP_BULK_APPROVE_LIMIT=100
PIXELS_GROUP_FURNITURE_CLEANUP_LIMIT=1000
PIXELS_GROUP_FORUM_PAGE_SIZE=50
PIXELS_GROUP_FORUM_SUBJECT_LIMIT=120
PIXELS_GROUP_FORUM_MESSAGE_LIMIT=4000
PIXELS_GROUP_FORUM_POST_COOLDOWN=3s
PIXELS_GROUP_FORUM_ACTIVE_WINDOW=168h
PIXELS_GROUP_CACHE_TTL=10m
PIXELS_GROUP_FORUM_CURSOR_TTL=5m
PIXELS_GROUP_DEACTIVATION_RETENTION=8760h

# Crafting altar and exact-batch Ecotron policy.
PIXELS_CRAFTING_ENABLED=true
PIXELS_CRAFTING_RECYCLER_ENABLED=true
PIXELS_CRAFTING_RECYCLER_BATCH_SIZE=8
# Independent rarity denominators in tier=chance form; tier 1 is guaranteed fallback.
PIXELS_CRAFTING_RECYCLER_RARITY_CHANCES=5=1000,4=100,3=20,2=5

# S3-compatible object storage used by Camera & Photos.
STORAGE_ENDPOINT=127.0.0.1:9000
STORAGE_PUBLIC_BASE_URL=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=pixels-camera
STORAGE_USE_SSL=true
STORAGE_PUBLIC_READ=true
STORAGE_UPLOAD_TIMEOUT=10s

# Camera upload policy. Prices and publication cooldown are managed in PostgreSQL.
PIXELS_CAMERA_ENABLED=true
PIXELS_CAMERA_CAPTURE_COOLDOWN=3s
PIXELS_CAMERA_MAX_PHOTO_BYTES=2097152
PIXELS_CAMERA_MAX_THUMBNAIL_BYTES=1048576
# Unreferenced active photos are abandoned after this duration.
PIXELS_CAMERA_PENDING_RETENTION=24h
# Replaced photos without furniture or publications retain a short grace period.
PIXELS_CAMERA_SUPERSEDED_RETENTION=1h
# One process-wide reconciler scans bounded batches at this cadence.
PIXELS_CAMERA_CLEANUP_INTERVAL=5m
# Failed object deletions become eligible for another attempt after this delay.
PIXELS_CAMERA_CLEANUP_RETRY=5m
PIXELS_CAMERA_CLEANUP_BATCH_SIZE=100

# Event-driven achievements, talents, quests, quizzes, and promotions.
# Disable only for operational recovery; default: true.
PIXELS_PROGRESSION_ENABLED=true
# Require the citizenship TRADE perk before direct trades; default: false.
PIXELS_PROGRESSION_TRADE_REQUIRES_PERK=false
# Required helpers talent level for guide duty; zero keeps permission-only gating.
PIXELS_PROGRESSION_GUIDE_MIN_TRACK_LEVEL=0
# Cadence for online-presence progress and write-behind persistence.
PIXELS_PROGRESSION_PRESENCE_INTERVAL=5m
PIXELS_PROGRESSION_FLUSH_INTERVAL=2s
# Optional stable salt for deterministic daily-quest selection.
PIXELS_PROGRESSION_DAILY_POOL_SEED=

# Server-authored room furniture games.
PIXELS_GAMES_ENABLED=true
PIXELS_GAMES_FREEZE_POINTS_FREEZE=10
PIXELS_GAMES_FREEZE_POINTS_BLOCK=1
PIXELS_GAMES_FREEZE_POINTS_EFFECT=3
PIXELS_GAMES_FREEZE_POWERUP_CHANCE=33
PIXELS_GAMES_FREEZE_MAX_SNOWBALLS=5
PIXELS_GAMES_FREEZE_MAX_LIVES=3
PIXELS_GAMES_FREEZE_LOOSE_SNOWBALLS=5
PIXELS_GAMES_FREEZE_LOOSE_BOOST=3
PIXELS_GAMES_FREEZE_FROZEN_SECONDS=5
PIXELS_GAMES_FREEZE_PROTECTION_SECONDS=10
PIXELS_GAMES_FREEZE_PROTECTION_STACK=true
PIXELS_GAMES_BANZAI_POINTS_STEAL=0
PIXELS_GAMES_BANZAI_POINTS_FILL=0
PIXELS_GAMES_BANZAI_POINTS_LOCK=1

# Nitro Game Center external URL launcher.
PIXELS_GAMECENTER_ENABLED=true
