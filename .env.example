# Pixels environment name.
# Default: development
PIXELS_ENV=development

# Host used by the protocol listener.
# Default: 127.0.0.1
PIXELS_HOST=127.0.0.1

# Port used by the protocol listener.
# Default: 3000
PIXELS_PORT=3000

# Access key required by private HTTP endpoints.
# Header: X-API-Key
# Use a long random value and share it only with trusted HTTP clients.
# Default: pixels-development-access-key-change-me
PIXELS_ACCESS_KEY=pixels-development-access-key-change-me

# Zap log level.
# Allowed values: debug, info, warn, error, dpanic, panic, fatal
# Default: info
LOG_LEVEL=info

# Zap log encoder.
# Allowed values: console, json
# Default: console
LOG_FORMAT=console

# Emit inline TOON logs for agent-friendly protocol tracing.
# Removes timestamps/callers and normalizes packet fields before TOON encoding.
# Default: false
TOON_CONSOLE=false

# JSON translation catalog path.
# Default: i18n/translations.json
PIXELS_I18N_PATH=i18n/translations.json

# Default locale used when no player locale is available.
# Default: es
PIXELS_I18N_DEFAULT_LOCALE=es

# Fallback locale used when a key is missing in the default locale.
# Default: en
PIXELS_I18N_FALLBACK_LOCALE=en

# Missing translation behavior.
# Allowed values: key, empty
# Default: key
PIXELS_I18N_MISSING_MODE=key

# Path to the JSON currency type catalog.
# Default: currency/types.json
PIXELS_CURRENCY_CATALOG_PATH=currency/types.json

# Comma-separated currency types that write an audit ledger entry.
# Types not listed still update their balances without ledger history.
# Default: -1 (credits only)
PIXELS_CURRENCY_LEDGER_TYPES=-1

# Redis address used by reusable storage components.
# Default: 127.0.0.1:6379
REDIS_ADDRESS=127.0.0.1:6379

# Redis username.
# Default: empty
REDIS_USERNAME=

# Redis password.
# Default: empty
REDIS_PASSWORD=

# Redis database number.
# Default: 0
REDIS_DATABASE=0

# Maximum time a doorbell request waits for approval.
# Default: 5m
PIXELS_ROOM_ENTRY_HANGOUT_TIMEOUT=5m

# Failed room password attempts allowed before lockout.
# Default: 5
PIXELS_ROOM_ENTRY_MAX_PASSWORD_ATTEMPTS=5

# Window in which failed room password attempts accumulate.
# Default: 5m
PIXELS_ROOM_ENTRY_ATTEMPT_WINDOW=5m

# Duration of a room password lockout, in seconds.
# The user-facing alert converts this value to seconds, minutes, hours, or days.
# Default: 600
PIXELS_ROOM_ENTRY_LOCKOUT_SECONDS=600

# Bcrypt cost used when room passwords are hashed.
# Default: 10
PIXELS_ROOM_ENTRY_PASSWORD_COST=10

# Lifetime of a one-time admin room entry bypass.
# Default: 10s
PIXELS_ROOM_ENTRY_TRUSTED_TTL=10s

# Minimum room mute duration accepted by the moderation service, in minutes.
PIXELS_ROOM_MODERATION_MIN_MUTE_MINUTES=1

# Maximum room mute duration accepted by the moderation service, in minutes.
PIXELS_ROOM_MODERATION_MAX_MUTE_MINUTES=1440

# Maximum Unicode runes accepted in a normal chat message.
# Default: 256
PIXELS_CHAT_MAX_MESSAGE_RUNES=256

# Loose room flood budget and expiration window.
# Default: 100 messages per 1s
PIXELS_CHAT_FLOOD_TIER0_MAX_MESSAGES=100
PIXELS_CHAT_FLOOD_TIER0_WINDOW=1s

# Normal room flood budget and expiration window.
# Default: 10 messages per 5s
PIXELS_CHAT_FLOOD_TIER1_MAX_MESSAGES=10
PIXELS_CHAT_FLOOD_TIER1_WINDOW=5s

# Strict room flood budget and expiration window.
# Default: 6 messages per 5s
PIXELS_CHAT_FLOOD_TIER2_MAX_MESSAGES=6
PIXELS_CHAT_FLOOD_TIER2_WINDOW=5s

# Persist private whispers in moderation history.
# Default: false
PIXELS_CHAT_LOG_WHISPERS=false

# Daily chat history partitions retained before DROP TABLE.
# Default: 14
PIXELS_CHAT_LOG_RETENTION_DAYS=14

# Maximum delay and row count for one asynchronous history COPY batch.
# Defaults: 2s and 200
PIXELS_CHAT_LOG_FLUSH_INTERVAL=2s
PIXELS_CHAT_LOG_FLUSH_BATCH_SIZE=200

# Non-blocking chat history queue capacity.
# Default: 4096
PIXELS_CHAT_LOG_QUEUE_SIZE=4096

# PostgreSQL host.
# Default: localhost
PIXELS_POSTGRES_HOST=localhost

# PostgreSQL port.
# Default: 5432
PIXELS_POSTGRES_PORT=5432

# PostgreSQL database name.
# Default: pixels
PIXELS_POSTGRES_DATABASE=pixels

# PostgreSQL user.
# Default: pixels
PIXELS_POSTGRES_USER=pixels

# PostgreSQL password for development.
# Default: pixels
PIXELS_POSTGRES_PASSWORD=pixels

# PostgreSQL SSL mode.
# Default: disable
PIXELS_POSTGRES_SSL_MODE=disable

# Maximum PostgreSQL pool connections.
# Default: 10
PIXELS_POSTGRES_MAX_CONNS=10

# Minimum PostgreSQL pool connections.
# Default: 1
PIXELS_POSTGRES_MIN_CONNS=1

# PostgreSQL connection timeout.
# Default: 5s
PIXELS_POSTGRES_CONNECT_TIMEOUT=5s

# PostgreSQL statement timeout.
# Default: 5s
PIXELS_POSTGRES_STATEMENT_TIMEOUT=5s

# PostgreSQL health check timeout.
# Default: 2s
PIXELS_POSTGRES_HEALTH_TIMEOUT=2s

# Default SSO ticket lifetime.
# Default: 5m
SSO_DEFAULT_TTL=5m

# HMAC key used to derive Redis storage keys for SSO tickets.
# Default: pixels-development-sso-key-change-me
SSO_KEY=pixels-development-sso-key-change-me

# Redis key prefix for SSO tickets.
# Default: pixels:sso
SSO_PREFIX=pixels:sso

# Maximum queued outbound WebSocket packets per connection.
# Default: 256
PIXELS_WS_QUEUE_SIZE=256

# Maximum duration for one WebSocket write.
# Default: 5s
PIXELS_WS_WRITE_TIMEOUT=5s

# Maximum duration for one WebSocket read.
# Default: 75s
PIXELS_WS_READ_TIMEOUT=75s

# Interval between server heartbeat pings.
# Default: 30s
PIXELS_WS_PING_INTERVAL=30s

# Maximum duration without a client pong before disconnecting.
# Default: 60s
PIXELS_WS_PONG_TIMEOUT=60s

# Maximum graceful close flushing duration.
# Default: 2s
PIXELS_WS_CLOSE_GRACE=2s

# Reject custom room floor plans that contain no usable tile.
# Default: true
PIXELS_ROOM_FLOORPLAN_REJECT_ZERO_HEIGHT=true

# Minimum delay between successful floor plan saves by one player.
# Default: 3s
PIXELS_ROOM_FLOORPLAN_SAVE_COOLDOWN=3s

# Allow paired furniture teleports to bypass locked destination room modes. Room bans always apply.
# Default: false
PIXELS_FURNITURE_TELEPORT_BYPASS_LOCKED=false
# Normal messenger friend-list capacity.
# Default: 200
PIXELS_MESSENGER_MAX_FRIENDS=200

# Active HC messenger friend-list capacity.
# Default: 500
PIXELS_MESSENGER_MAX_FRIENDS_CLUB=500

# Maximum players returned by a username-prefix search.
# Default: 50
PIXELS_MESSENGER_SEARCH_MAX_RESULTS=50

# Shared Redis lifetime for username-prefix search results.
# Default: 30s
PIXELS_MESSENGER_SEARCH_CACHE_TTL=30s

# Minimum interval between messenger searches by one player.
# Default: 3s
PIXELS_MESSENGER_SEARCH_THROTTLE=3s

# Minimum interval between private messages by one sender.
# Default: 750ms
PIXELS_MESSENGER_CHAT_THROTTLE=750ms

# Apply the global hotel word filter to private messages.
# Default: false
PIXELS_MESSENGER_CHAT_FILTER_ENABLED=false

# Persist accepted private messages for moderation review.
# Default: false
PIXELS_MESSENGER_CHAT_LOG_ENABLED=false

# Interval between subscription entitlement and payday scheduler passes.
# Default: 1m
PIXELS_SUBSCRIPTION_TICK_INTERVAL=1m

# Duration of one HC payday accounting cycle.
# Default: 744h (31 days)
PIXELS_SUBSCRIPTION_PAYDAY_INTERVAL=744h

# Fraction of eligible catalog credit spending returned at payday.
# Default: 0.10
PIXELS_SUBSCRIPTION_KICKBACK_PERCENTAGE=0.10

# Currency type receiving HC payday rewards; -1 identifies credits.
# Default: -1
PIXELS_SUBSCRIPTION_PAYDAY_CURRENCY_TYPE=-1

# Enable Nitro Marketplace operations.
PIXELS_MARKETPLACE_ENABLED=true
# Buyer commission percentage, rounded upward.
PIXELS_MARKETPLACE_COMMISSION_PERCENT=1
# Credits charged per fixed Marketplace token package.
PIXELS_MARKETPLACE_TOKEN_COST=1
# Tokens granted per package.
PIXELS_MARKETPLACE_TOKEN_PACKAGE_SIZE=5
# Promoted-listing cost projected to Nitro; promotion is currently disabled.
PIXELS_MARKETPLACE_ADVERTISEMENT_COST=0
# Inclusive seller-price limits.
PIXELS_MARKETPLACE_MIN_PRICE=1
PIXELS_MARKETPLACE_MAX_PRICE=1000000
# Open offer and historical display lifetimes.
PIXELS_MARKETPLACE_OFFER_DURATION=48h
PIXELS_MARKETPLACE_DISPLAY_DURATION=168h
# Shared search cache and expiry scheduler cadence.
PIXELS_MARKETPLACE_SEARCH_CACHE_TTL=30s
PIXELS_MARKETPLACE_EXPIRY_INTERVAL=1m

# Enable direct player trading.
PIXELS_TRADE_ENABLED=true
# Minimum interval between trade-start requests.
PIXELS_TRADE_START_THROTTLE=10s
# Maximum offered furniture per participant.
PIXELS_TRADE_MAX_ITEMS=12
# Persist completed trade audit records.
PIXELS_TRADE_AUDIT_ENABLED=true
